# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copia este archivo como .env.local y llena tus claves.
# .env.local está en .gitignore — NUNCA se sube a GitHub.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Supabase — Settings > API en tu proyecto de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic Claude — console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# Groq — console.groq.com
GROQ_API_KEY=gsk_...

# OpenAI — platform.openai.com/api-keys
# Usado para generar imágenes de recetas con DALL-E 3 (~$0.04 USD por imagen)
OPENAI_API_KEY=sk-...

# Google Custom Search — ya no se usa, reemplazado por DALL-E 3
# GOOGLE_API_KEY=AIzaSy...
# GOOGLE_SEARCH_ENGINE_ID=xxxxxxxxxxxxxxxxx
